{
  "schema_version": "0.1.0",
  "project": {
    "name": "example-next-strapi",
    "type": "cms_website",
    "adapter": "nextjs-strapi"
  },
  "paths": {
    "contract": "framework/contract.yml",
    "gates": "framework/gates.yml",
    "lanes": "framework/lanes.yml",
    "proof_report": ".grounding/proof-report.md",
    "logs_dir": ".grounding/logs",
    "screenshots_dir": ".grounding/screenshots"
  },
  "commands": {
    "install": "npm install",
    "lint": "npm run lint --if-present",
    "typecheck": "npm run typecheck --if-present",
    "build": "npm run build",
    "test": "npm test --if-present",
    "screenshot": "npm run test:e2e --if-present",
    "package": ""
  },
  "gates": {
    "G0": [
      "verify_contract"
    ],
    "G1": [
      "install",
      "lint",
      "typecheck",
      "build"
    ],
    "G2": [
      "test",
      "screenshot"
    ],
    "G3": [
      "collect_proof"
    ],
    "G4": [
      "write_report",
      "validate_proof"
    ]
  }
}

