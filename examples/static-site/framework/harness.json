{
  "schema_version": "0.1.0",
  "project": {
    "name": "example-static-site",
    "type": "website",
    "adapter": "static-site"
  },
  "paths": {
    "contract": "framework/contract.yml",
    "gates": "framework/gates.yml",
    "lanes": "framework/lanes.yml",
    "proof_report": ".grounding/proof-report.md",
    "logs_dir": ".grounding/logs",
    "screenshots_dir": ".grounding/screenshots"
  },
  "commands": {
    "install": "skip",
    "lint": "skip",
    "typecheck": "skip",
    "build": "skip",
    "test": "skip",
    "screenshot": "skip",
    "package": "skip"
  },
  "gates": {
    "G0": [
      "verify_contract"
    ],
    "G1": [
      "install",
      "lint",
      "build"
    ],
    "G2": [
      "test"
    ],
    "G3": [
      "collect_proof"
    ],
    "G4": [
      "write_report",
      "validate_proof"
    ]
  }
}

