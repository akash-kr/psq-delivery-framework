{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:psq:delivery-framework:proof-schema:1",
  "title": "PSQ Delivery Proof Report",
  "type": "object",
  "required": [
    "schema_version",
    "project",
    "contract_id",
    "contract_version",
    "source_revision",
    "timestamp",
    "output_delivered",
    "proof",
    "gate_results",
    "risks",
    "milestone_ready"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "contract_id": {
      "type": "string"
    },
    "contract_version": {
      "type": "string"
    },
    "source_revision": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "output_delivered": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proof": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "gate_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "gate",
          "status"
        ],
        "properties": {
          "gate": {
            "type": "string"
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "blocked"
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "milestone_ready": {
      "type": "boolean"
    },
    "uat_approval": {
      "type": ["object", "null"],
      "required": ["contract_id", "contract_version", "source_revision", "status", "approved_by", "approved_at"],
      "properties": {
        "contract_id": {"type": "string"},
        "contract_version": {"type": "string"},
        "source_revision": {"type": "string"},
        "status": {"type": "string"},
        "approved_by": {"type": "string"},
        "approved_at": {"type": "string"}
      }
    }
  }
}
