{
  "schema_version": "0.1.0",
  "project": {
    "name": "grounded-delivery-framework",
    "type": "framework",
    "adapter": "static-site"
  },
  "paths": {
    "contract": "framework/contract.yml",
    "gates": "framework/gates.yml",
    "lanes": "framework/lanes.yml",
    "proof_report": ".grounding/proof-report.md",
    "logs_dir": ".grounding/logs",
    "screenshots_dir": ".grounding/screenshots"
  },
  "commands": {
    "install": "",
    "lint": "",
    "typecheck": "",
    "build": "",
    "test": "",
    "screenshot": "",
    "package": ""
  },
  "gates": {
    "G0": [
      "verify_contract"
    ],
    "G1": [
      "install",
      "lint",
      "typecheck",
      "build"
    ],
    "G2": [
      "test"
    ],
    "G3": [
      "collect_proof"
    ],
    "G4": [
      "write_report"
    ]
  },
  "proof": {
    "required": [
      "contract",
      "gate_results",
      "commands",
      "risks",
      "decision_needed"
    ],
    "optional": [
      "screenshots",
      "citations",
      "install_logs",
      "test_logs"
    ]
  }
}

