{
  "schema_version": "1.0.0",
  "command_timeout_seconds": 1800,
  "project": {
    "name": "psq-delivery-framework",
    "type": "framework",
    "adapter": "python"
  },
  "paths": {
    "contract": "framework/contract.yml",
    "gates": "framework/gates.yml",
    "proof_report": ".grounding/proof-report.md",
    "proof_json": ".grounding/proof-report.json",
    "gate_status": ".grounding/gate-status.json",
    "uat_approval": ".grounding/uat-approval.json",
    "milestone_release": ".grounding/milestone-release.json",
    "logs_dir": ".grounding/logs",
    "screenshots_dir": ".grounding/screenshots"
  },
  "commands": {
    "install": "skip",
    "lint": "python3 -m py_compile scripts/gdf.py tools/escalation-watcher.py",
    "typecheck": "skip",
    "build": "skip",
    "unit_test": "python3 -m unittest discover -s tests",
    "ai_review": "skip",
    "e2e_test": "skip",
    "visual_test": "skip",
    "integration_test": "skip"
  },
  "gates": {
    "G1": [
      "verify_contract",
      "install",
      "lint",
      "typecheck",
      "build",
      "unit_test",
      "ai_review"
    ],
    "G2": [
      "e2e_test",
      "visual_test"
    ],
    "G3": [
      "integration_test"
    ],
    "G4": [
      "verify_uat_approval"
    ]
  },
  "requires": {
    "G2": ["G1"],
    "G3": ["G1", "G2"],
    "G4": ["G1", "G2", "G3"]
  },
  "proof": {
    "required": [
      "contract",
      "gate_results",
      "commands",
      "risks",
      "source_revision"
    ],
    "optional": [
      "screenshots",
      "install_logs",
      "test_logs"
    ]
  }
}
