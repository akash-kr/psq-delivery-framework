{
  "schema_version": "0.1.0",
  "project": {
    "name": "grounded-delivery-framework",
    "type": "framework",
    "adapter": "python"
  },
  "paths": {
    "contract": "framework/contract.yml",
    "gates": "framework/gates.yml",
    "lanes": "framework/lanes.yml",
    "proof_report": ".grounding/proof-report.md",
    "proof_json": ".grounding/proof-report.json",
    "gate_status": ".grounding/gate-status.json",
    "logs_dir": ".grounding/logs",
    "screenshots_dir": ".grounding/screenshots"
  },
  "commands": {
    "install": "skip",
    "lint": "python3 -m py_compile scripts/gdf.py tools/review-server.py tools/escalation-watcher.py",
    "typecheck": "skip",
    "build": "skip",
    "test": "python3 -m unittest discover -s tests",
    "screenshot": "skip",
    "package": "skip"
  },
  "gates": {
    "G0": [
      "verify_contract"
    ],
    "G1": [
      "install",
      "lint",
      "typecheck",
      "build"
    ],
    "G2": [
      "test",
      "screenshot"
    ],
    "G3": [
      "collect_proof"
    ],
    "G4": [
      "write_report",
      "validate_proof"
    ]
  },
  "proof": {
    "required": [
      "contract",
      "gate_results",
      "commands",
      "risks",
      "decision_needed"
    ],
    "optional": [
      "screenshots",
      "citations",
      "install_logs",
      "test_logs"
    ]
  }
}
